<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>College Login</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:linear-gradient(to right,#004e92,#000428);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.login-box{
    width:350px;
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.4);
    text-align:center;
}

.login-box img{
    width:90px;
    height:90px;
    margin-bottom:15px;
}

.login-box h2{
    color:#004e92;
    margin-bottom:20px;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:5px;
    font-size:16px;
}

button{
    width:100%;
    padding:12px;
    background:#004e92;
    color:white;
    border:none;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#0073e6;
}

p{
    margin-top:15px;
    font-size:14px;
}
</style>

</head>
<body>

<div class="login-box">

<img src="college-logo.png" alt="College Logo">

<h2>ABC College Login</h2>

<form>

<input type="text" placeholder="Enter Register Number" required>

<input type="password" placeholder="Enter Password" required>

<button type="submit">Login</button>

</form>

<p>© 2026 ABC College</p>

</div>

</body>
</html>
