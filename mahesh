<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEC Student Login</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:linear-gradient(135deg,#003366,#0066cc);
}

.login-box{
    width:360px;
    background:#fff;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 20px rgba(0,0,0,0.3);
    text-align:center;
}

.logo{
    width:100px;
    height:100px;
    margin-bottom:15px;
}

h2{
    color:#003366;
    margin-bottom:5px;
}

h4{
    color:#666;
    margin-bottom:20px;
    font-weight:normal;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:5px;
    font-size:16px;
}

button{
    width:100%;
    padding:12px;
    background:#003366;
    color:white;
    border:none;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#0055aa;
}

.footer{
    margin-top:20px;
    font-size:13px;
    color:#555;
}
</style>

</head>
<body>

<div class="login-box">

<img src="college-logo.png" class="logo" alt="APEC Logo">

<h2>Adhiparasakthi Engineering College</h2>
<h4>Student Login Portal</h4>

<form>

<input type="text" placeholder="Register Number" required>

<input type="password" placeholder="Password" required>

<button type="submit">Login</button>

</form>

<div class="footer">
© 2026 Adhiparasakthi Engineering College
</div>

</div>

</body>
</html>
